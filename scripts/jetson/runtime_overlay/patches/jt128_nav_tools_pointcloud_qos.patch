+rclcpp::QoS makePointCloudQos(const int depth, const bool reliable)
+{
+  const auto safe_depth = static_cast<size_t>(std::max(1, depth));
+  auto qos = rclcpp::QoS(rclcpp::KeepLast(safe_depth)).durability_volatile();
+  if (reliable) {
+    qos.reliable();
+  } else {
+    qos.best_effort();
+  }
+  return qos;
+}
+
+double stampToSec(const builtin_interfaces::msg::Time & stamp)
+{
+  return static_cast<double>(stamp.sec) + static_cast<double>(stamp.nanosec) * 1.0e-9;
+}
