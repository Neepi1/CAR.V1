+  void publishStatus()
+  {
+    if (!status_publisher_) {
+      return;
+    }
+    const auto now_steady = std::chrono::steady_clock::now();
+    const double elapsed_sec = std::max(
+      std::chrono::duration<double>(now_steady - previous_status_time_).count(), 1.0e-3);
+    const auto input_delta = input_callback_count_ - previous_input_callback_count_;
+    const auto output_delta = output_publish_count_ - previous_output_publish_count_;
+
+    std_msgs::msg::String msg;
+    std::ostringstream stream;
+    stream << std::fixed << std::setprecision(3)
+           << "input_topic=" << input_topic_
+           << " output_topic=" << output_topic_
+           << " input_callback_hz=" << static_cast<double>(input_delta) / elapsed_sec
+           << " output_points_nav_hz=" << static_cast<double>(output_delta) / elapsed_sec
+           << " last_processing_ms=" << last_processing_ms_
+           << " skipped_transform=" << skipped_transform_count_
+           << " input_cloud_points=" << input_cloud_points_
+           << " input_cloud_bytes=" << input_cloud_bytes_
+           << " input_last_stamp_age_ms=" << input_last_stamp_age_ms_
+           << " output_cloud_points=" << output_cloud_points_
+           << " subscription_qos_depth=" << input_qos_depth_
+           << " subscription_qos_reliable=" << (input_reliable_ ? "true" : "false");
+    msg.data = stream.str();
+    status_publisher_->publish(msg);
+
+    previous_status_time_ = now_steady;
+    previous_input_callback_count_ = input_callback_count_;
+    previous_output_publish_count_ = output_publish_count_;
