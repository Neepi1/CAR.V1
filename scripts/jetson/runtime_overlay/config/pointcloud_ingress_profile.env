# Phase D1 LiDAR ingress selector.
#
# separate_process:
#   hesai_ros_driver_node -> /jt128/vendor/points_raw -> pointcloud_accel_axis_node
#
# driver_integrated:
#   guarded for now; requires a repo-owned Hesai driver overlay before it can
#   replace the standalone Hesai executable and call AccelCore from decode.
export NJRH_POINTCLOUD_INGRESS_PROFILE="${NJRH_POINTCLOUD_INGRESS_PROFILE:-separate_process}"
