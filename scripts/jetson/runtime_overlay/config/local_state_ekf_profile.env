# Runtime local-state EKF profile override.
#
# wheel_only keeps LOCAL_STATE_MODE=ekf and robot_localization as the canonical
# odom->base_link owner, but removes EKF imu0 fusion for chassis-odom isolation.
# Restore the default fusion profile by changing this to wheel_imu.
export NJRH_LOCAL_STATE_EKF_PROFILE="${NJRH_LOCAL_STATE_EKF_PROFILE:-wheel_only}"
