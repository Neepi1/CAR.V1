# Runtime AMCL localization profile.
#
# gated is the production correction mode: AMCL is connected as a continuous
# candidate source, and robot_localization_bridge accepts only small,
# covariance-gated corrections into map->odom.
# disabled keeps Isaac-triggered-only localization behavior.
# shadow starts AMCL and lets robot_localization_bridge compute/report AMCL
# candidate corrections without updating map->odom.
# gated starts AMCL and lets robot_localization_bridge accept only small,
# covariance-gated AMCL corrections into map->odom.
export NJRH_AMCL_LOCALIZATION_MODE="${NJRH_AMCL_LOCALIZATION_MODE:-gated}"
export NJRH_AMCL_PARAMS_FILE="${NJRH_AMCL_PARAMS_FILE:-${NJRH_OVERLAY_ROOT:-/workspaces/njrh-v3/workspace1/scripts/jetson/runtime_overlay}/config/amcl_shadow.yaml}"
export NJRH_AMCL_POSE_TOPIC="${NJRH_AMCL_POSE_TOPIC:-/amcl_pose}"
export NJRH_AMCL_INITIAL_POSE_TOPIC="${NJRH_AMCL_INITIAL_POSE_TOPIC:-/initialpose}"
export NJRH_AMCL_DISABLE_DURING_MAPPING="${NJRH_AMCL_DISABLE_DURING_MAPPING:-true}"
export NJRH_AMCL_DISABLE_DURING_DOCKING_FINE="${NJRH_AMCL_DISABLE_DURING_DOCKING_FINE:-true}"
export NJRH_AMCL_DISABLE_DURING_MANUAL="${NJRH_AMCL_DISABLE_DURING_MANUAL:-true}"

# Phase A1.2 startup/readiness gates. AMCL has its own TF buffer, so startup
# waits for canonical TF edges to exist, lets that AMCL-local cache warm, then
# seeds /initialpose with retries and requires a fresh /amcl_pose before the
# runtime reports AMCL continuous localization as ready.
export NJRH_AMCL_TF_WARMUP_SEC="${NJRH_AMCL_TF_WARMUP_SEC:-3.0}"
export NJRH_AMCL_LIFECYCLE_TRANSITION_TIMEOUT_SEC="${NJRH_AMCL_LIFECYCLE_TRANSITION_TIMEOUT_SEC:-20}"
export NJRH_AMCL_SEED_RETRY_COUNT="${NJRH_AMCL_SEED_RETRY_COUNT:-5}"
export NJRH_AMCL_SEED_RETRY_PERIOD_MS="${NJRH_AMCL_SEED_RETRY_PERIOD_MS:-300}"
export NJRH_AMCL_POSE_FRESH_TIMEOUT_SEC="${NJRH_AMCL_POSE_FRESH_TIMEOUT_SEC:-10.0}"
export NJRH_AMCL_POSE_MAX_AGE_SEC="${NJRH_AMCL_POSE_MAX_AGE_SEC:-1.0}"
export NJRH_AMCL_READY_REQUIRE_FRESH_POSE="${NJRH_AMCL_READY_REQUIRE_FRESH_POSE:-true}"

# /scan_amcl is an AMCL production input, not a debug topic. It preserves the
# original /scan stamp/frame/ranges and only admits scans that are recent and
# transformable into odom at the original stamp.
export NJRH_AMCL_SCAN_ADMISSION_ENABLED="${NJRH_AMCL_SCAN_ADMISSION_ENABLED:-true}"
export NJRH_AMCL_SCAN_ADMISSION_IMPL="${NJRH_AMCL_SCAN_ADMISSION_IMPL:-cpp}"
export NJRH_AMCL_SCAN_INPUT_TOPIC="${NJRH_AMCL_SCAN_INPUT_TOPIC:-/scan}"
export NJRH_AMCL_SCAN_OUTPUT_TOPIC="${NJRH_AMCL_SCAN_OUTPUT_TOPIC:-/scan_amcl}"
export NJRH_AMCL_SCAN_ADMISSION_STATUS_TOPIC="${NJRH_AMCL_SCAN_ADMISSION_STATUS_TOPIC:-/amcl_scan_admission/status}"
export NJRH_AMCL_SCAN_RATE_HZ="${NJRH_AMCL_SCAN_RATE_HZ:-5.0}"
export NJRH_AMCL_SCAN_PRESERVE_STAMP="${NJRH_AMCL_SCAN_PRESERVE_STAMP:-true}"
export NJRH_AMCL_SCAN_DROP_IF_TF_UNAVAILABLE="${NJRH_AMCL_SCAN_DROP_IF_TF_UNAVAILABLE:-true}"
export NJRH_AMCL_SCAN_MAX_AGE_MS="${NJRH_AMCL_SCAN_MAX_AGE_MS:-250.0}"
export NJRH_AMCL_SCAN_WAIT_FOR_TF_TIMEOUT_MS="${NJRH_AMCL_SCAN_WAIT_FOR_TF_TIMEOUT_MS:-20.0}"
export NJRH_AMCL_SCAN_FRAME_REQUIRED="${NJRH_AMCL_SCAN_FRAME_REQUIRED:-lidar_level_link}"
export NJRH_AMCL_SCAN_TARGET_FRAME="${NJRH_AMCL_SCAN_TARGET_FRAME:-odom}"
export NJRH_AMCL_SCAN_ADMISSION_ONLY_AFTER_SEED="${NJRH_AMCL_SCAN_ADMISSION_ONLY_AFTER_SEED:-true}"
export NJRH_AMCL_SCAN_ADMISSION_ONLY_AFTER_TF_WARMUP="${NJRH_AMCL_SCAN_ADMISSION_ONLY_AFTER_TF_WARMUP:-true}"

# transform_tolerance is intentionally left at the AMCL YAML default unless a
# field A/B test proves it is the active drop cause.
export NJRH_AMCL_TRANSFORM_TOLERANCE_PROFILE="${NJRH_AMCL_TRANSFORM_TOLERANCE_PROFILE:-default}"
