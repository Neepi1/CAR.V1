# Runtime AMCL localization profile.
#
# gated is the default active AMCL integration mode: AMCL is connected as a
# continuous candidate source and robot_localization_bridge accepts only small,
# covariance-gated corrections into map->odom.
# disabled keeps Isaac-triggered-only localization behavior.
# shadow starts AMCL and lets robot_localization_bridge compute/report AMCL
# candidate corrections without updating map->odom.
# gated starts AMCL and lets robot_localization_bridge accept only small,
# covariance-gated AMCL corrections into map->odom.
export NJRH_AMCL_LOCALIZATION_MODE="${NJRH_AMCL_LOCALIZATION_MODE:-gated}"
export NJRH_AMCL_PARAMS_FILE="${NJRH_AMCL_PARAMS_FILE:-${NJRH_OVERLAY_ROOT:-/workspaces/njrh-v3/workspace1/scripts/jetson/runtime_overlay}/config/amcl_shadow.yaml}"
export NJRH_AMCL_POSE_TOPIC="${NJRH_AMCL_POSE_TOPIC:-/amcl_pose}"
export NJRH_AMCL_INITIAL_POSE_TOPIC="${NJRH_AMCL_INITIAL_POSE_TOPIC:-/initialpose}"
export NJRH_AMCL_DISABLE_DURING_MAPPING="${NJRH_AMCL_DISABLE_DURING_MAPPING:-true}"
export NJRH_AMCL_DISABLE_DURING_DOCKING_FINE="${NJRH_AMCL_DISABLE_DURING_DOCKING_FINE:-true}"
export NJRH_AMCL_DISABLE_DURING_MANUAL="${NJRH_AMCL_DISABLE_DURING_MANUAL:-true}"
