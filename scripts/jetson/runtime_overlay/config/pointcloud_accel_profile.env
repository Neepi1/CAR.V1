# Runtime-selected pointcloud acceleration profile.
# Valid values:
#   legacy:     current verified local_branch + nav_cloud_preprocessor path
#   ipc_worker: same-process navigation workers; /lidar_points stays full trunk
#   nitros:     Isaac ROS NITROS same-process island skeleton when available
export NJRH_POINTCLOUD_ACCEL_PROFILE="${NJRH_POINTCLOUD_ACCEL_PROFILE:-legacy}"
