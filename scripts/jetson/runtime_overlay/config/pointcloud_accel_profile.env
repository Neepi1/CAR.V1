# Runtime-selected pointcloud acceleration profile.
# Valid values:
#   legacy:     diagnostic rollback for the old local_perception path
#   ipc_worker: production /lidar_points trunk plus same-process /scan worker
#   nitros:     Isaac ROS NITROS same-process island skeleton when available
export NJRH_POINTCLOUD_ACCEL_PROFILE="${NJRH_POINTCLOUD_ACCEL_PROFILE:-ipc_worker}"
