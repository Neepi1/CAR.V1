# shellcheck shell=bash
#
# Jetson Orin 8-core runtime CPU affinity policy.
# Percent CPU in ps is one-core based, so these sets reserve scheduler
# headroom for the low-latency control and TF path while keeping heavy
# lidar/perception work away from it.

export NJRH_CPU_AFFINITY_ENABLED="${NJRH_CPU_AFFINITY_ENABLED:-true}"

# Service groups.
export NJRH_CPUSET_SYSTEM="${NJRH_CPUSET_SYSTEM:-0}"
export NJRH_CPUSET_BASE_CONTROL="${NJRH_CPUSET_BASE_CONTROL:-1}"
export NJRH_CPUSET_TF_STATE="${NJRH_CPUSET_TF_STATE:-2}"
export NJRH_CPUSET_NAV_CONTROL="${NJRH_CPUSET_NAV_CONTROL:-3}"
export NJRH_CPUSET_LIDAR_PERCEPTION="${NJRH_CPUSET_LIDAR_PERCEPTION:-4,5}"
# Keep the UDP driver, full-density pointcloud fan-out and IMU remap on
# separate cores. The JT128 driver is burst-sensitive, while pointcloud remap
# spends most time on PointCloud2 memory copies and must not share the same core
# with another high-frequency ingress node.
export NJRH_CPUSET_LIDAR_DRIVER="${NJRH_CPUSET_LIDAR_DRIVER:-4}"
export NJRH_CPUSET_LIDAR_PIPELINE="${NJRH_CPUSET_LIDAR_PIPELINE:-5}"
export NJRH_CPUSET_LOCALIZATION="${NJRH_CPUSET_LOCALIZATION:-6}"
# Planner, BT, and behavior action acknowledgements must not be pinned to the
# system core. Share the Nav2 control-wide pool so behavior-tree ticks and
# planner/controller action handshakes have scheduler headroom during JT128,
# AMCL, and map->odom load.
export NJRH_CPUSET_NAV_PLANNING="${NJRH_CPUSET_NAV_PLANNING:-3,5}"
export NJRH_CPUSET_NAV_SUPERVISION="${NJRH_CPUSET_NAV_SUPERVISION:-${NJRH_CPUSET_SYSTEM},${NJRH_CPUSET_BASE_CONTROL}}"
export NJRH_CPUSET_MAPPING_FRONTEND="${NJRH_CPUSET_MAPPING_FRONTEND:-6,7}"
export NJRH_CPUSET_MAPPING_BACKEND="${NJRH_CPUSET_MAPPING_BACKEND:-7}"

# Phase C1 controller/local_costmap CPU-set A/B.
# Nav2 controller_server hosts the local costmap in this runtime, so the
# profile controls that combined process without moving EKF CPU2, JT128 CPU4,
# AMCL scan admission CPU6, or map->odom bridge CPU7.
export NJRH_NAV2_CONTROLLER_CPU_PROFILE="${NJRH_NAV2_CONTROLLER_CPU_PROFILE:-current}"
export NJRH_CPUSET_NAV2_CONTROLLER_CURRENT="${NJRH_CPUSET_NAV2_CONTROLLER_CURRENT:-3}"
export NJRH_CPUSET_NAV2_CONTROLLER_WIDE="${NJRH_CPUSET_NAV2_CONTROLLER_WIDE:-3,5}"

njrh_resolve_nav2_controller_cpuset_profile() {
  case "${NJRH_NAV2_CONTROLLER_CPU_PROFILE}" in
    current)
      export NJRH_CPUSET_CONTROLLER_SERVER="${NJRH_CPUSET_NAV2_CONTROLLER_CURRENT}"
      ;;
    control_wide)
      export NJRH_CPUSET_CONTROLLER_SERVER="${NJRH_CPUSET_NAV2_CONTROLLER_WIDE}"
      ;;
    *)
      echo "[runtime-overlay] invalid NJRH_NAV2_CONTROLLER_CPU_PROFILE=${NJRH_NAV2_CONTROLLER_CPU_PROFILE}; expected current or control_wide" >&2
      return 2 2>/dev/null || exit 2
      ;;
  esac
}
njrh_resolve_nav2_controller_cpuset_profile

# Future arm reservation. These are not consumed by the current stack yet,
# but keeping the names here prevents the navigation policy from claiming
# all cores when arm control is added.
export NJRH_CPUSET_ARM_CONTROL="${NJRH_CPUSET_ARM_CONTROL:-6}"
export NJRH_CPUSET_ARM_PLANNING="${NJRH_CPUSET_ARM_PLANNING:-7}"

# Concrete runtime services.
export NJRH_CPUSET_ROBOT_API_SERVER="${NJRH_CPUSET_ROBOT_API_SERVER:-${NJRH_CPUSET_SYSTEM}}"
export NJRH_CPUSET_RUNTIME_HEALTH_GUARD="${NJRH_CPUSET_RUNTIME_HEALTH_GUARD:-${NJRH_CPUSET_SYSTEM}}"
export NJRH_CPUSET_RANGER_BASE_NODE="${NJRH_CPUSET_RANGER_BASE_NODE:-${NJRH_CPUSET_BASE_CONTROL}}"
export NJRH_CPUSET_ROBOT_SAFETY="${NJRH_CPUSET_ROBOT_SAFETY:-${NJRH_CPUSET_BASE_CONTROL}}"
export NJRH_CPUSET_VELOCITY_SMOOTHER="${NJRH_CPUSET_VELOCITY_SMOOTHER:-${NJRH_CPUSET_BASE_CONTROL}}"
export NJRH_CPUSET_RANGER_MINI3_MODE_CONTROLLER="${NJRH_CPUSET_RANGER_MINI3_MODE_CONTROLLER:-${NJRH_CPUSET_BASE_CONTROL}}"
export NJRH_CPUSET_DOCKING_MANAGER="${NJRH_CPUSET_DOCKING_MANAGER:-${NJRH_CPUSET_BASE_CONTROL}}"

export NJRH_CPUSET_ROBOT_LOCAL_STATE="${NJRH_CPUSET_ROBOT_LOCAL_STATE:-${NJRH_CPUSET_TF_STATE}}"
export NJRH_CPUSET_ROBOT_LOCAL_STATE_ODOM_PREPROCESSOR="${NJRH_CPUSET_ROBOT_LOCAL_STATE_ODOM_PREPROCESSOR:-${NJRH_CPUSET_TF_STATE}}"
export NJRH_CPUSET_ROBOT_LOCAL_STATE_IMU_BIAS_FILTER="${NJRH_CPUSET_ROBOT_LOCAL_STATE_IMU_BIAS_FILTER:-${NJRH_CPUSET_TF_STATE}}"
# Keep map->odom off the EKF/local-odom core. When FAST-LIO2 is not resident
# during navigation, CPU7 is reserved for bridge timers and mapping backend work.
export NJRH_CPUSET_ROBOT_LOCALIZATION_BRIDGE="${NJRH_CPUSET_ROBOT_LOCALIZATION_BRIDGE:-7}"

export NJRH_CPUSET_COLLISION_MONITOR="${NJRH_CPUSET_COLLISION_MONITOR:-${NJRH_CPUSET_BASE_CONTROL}}"
export NJRH_CPUSET_LOCAL_COSTMAP="${NJRH_CPUSET_LOCAL_COSTMAP:-${NJRH_CPUSET_CONTROLLER_SERVER}}"

export NJRH_CPUSET_HESAI_ROS_DRIVER="${NJRH_CPUSET_HESAI_ROS_DRIVER:-${NJRH_CPUSET_LIDAR_DRIVER}}"
export NJRH_CPUSET_POINTCLOUD_AXIS_REMAP="${NJRH_CPUSET_POINTCLOUD_AXIS_REMAP:-${NJRH_CPUSET_LIDAR_PIPELINE}}"
export NJRH_CPUSET_POINTCLOUD_ACCEL_CONTAINER="${NJRH_CPUSET_POINTCLOUD_ACCEL_CONTAINER:-5}"
export NJRH_CPUSET_POINTCLOUD_ACCEL_LOCAL_WORKER="${NJRH_CPUSET_POINTCLOUD_ACCEL_LOCAL_WORKER:-6}"
export NJRH_CPUSET_POINTCLOUD_ACCEL_SCAN_WORKER="${NJRH_CPUSET_POINTCLOUD_ACCEL_SCAN_WORKER:-7}"
export NJRH_CPUSET_NITROS_POINTCLOUD_CONTAINER="${NJRH_CPUSET_NITROS_POINTCLOUD_CONTAINER:-5,6,7}"
export NJRH_CPUSET_POINTCLOUD_PERCEPTION_PIPELINE="${NJRH_CPUSET_POINTCLOUD_PERCEPTION_PIPELINE:-${NJRH_CPUSET_LIDAR_PIPELINE},${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_POINTCLOUD_DOWNSAMPLE="${NJRH_CPUSET_POINTCLOUD_DOWNSAMPLE:-${NJRH_CPUSET_LIDAR_PIPELINE}}"
export NJRH_CPUSET_POINTCLOUD_FASTLIO_REMAP="${NJRH_CPUSET_POINTCLOUD_FASTLIO_REMAP:-${NJRH_CPUSET_LIDAR_PIPELINE}}"
export NJRH_CPUSET_IMU_AXIS_REMAP="${NJRH_CPUSET_IMU_AXIS_REMAP:-${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_NAV_CLOUD_PREPROCESSOR="${NJRH_CPUSET_NAV_CLOUD_PREPROCESSOR:-${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_ROBOT_LOCAL_PERCEPTION="${NJRH_CPUSET_ROBOT_LOCAL_PERCEPTION:-6}"

export NJRH_CPUSET_OCCUPANCY_GRID_LOCALIZER="${NJRH_CPUSET_OCCUPANCY_GRID_LOCALIZER:-${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_ROBOT_GLOBAL_LOCALIZATION="${NJRH_CPUSET_ROBOT_GLOBAL_LOCALIZATION:-${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_LASER_SCAN_TO_FLATSCAN="${NJRH_CPUSET_LASER_SCAN_TO_FLATSCAN:-${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_POINTCLOUD_TO_LASERSCAN="${NJRH_CPUSET_POINTCLOUD_TO_LASERSCAN:-${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_SCAN_REPUBLISHER="${NJRH_CPUSET_SCAN_REPUBLISHER:-${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_AMCL="${NJRH_CPUSET_AMCL:-${NJRH_CPUSET_LOCALIZATION}}"
export NJRH_CPUSET_AMCL_SCAN_ADMISSION="${NJRH_CPUSET_AMCL_SCAN_ADMISSION:-${NJRH_CPUSET_LOCALIZATION}}"

export NJRH_CPUSET_PLANNER_SERVER="${NJRH_CPUSET_PLANNER_SERVER:-${NJRH_CPUSET_NAV_PLANNING}}"
export NJRH_CPUSET_BT_NAVIGATOR="${NJRH_CPUSET_BT_NAVIGATOR:-${NJRH_CPUSET_NAV_PLANNING}}"
export NJRH_CPUSET_BEHAVIOR_SERVER="${NJRH_CPUSET_BEHAVIOR_SERVER:-${NJRH_CPUSET_NAV_PLANNING}}"
export NJRH_CPUSET_SMOOTHER_SERVER="${NJRH_CPUSET_SMOOTHER_SERVER:-${NJRH_CPUSET_NAV_PLANNING}}"
export NJRH_CPUSET_WAYPOINT_FOLLOWER="${NJRH_CPUSET_WAYPOINT_FOLLOWER:-${NJRH_CPUSET_NAV_PLANNING}}"
# Filter mask/info servers and lifecycle heartbeat supervision are light but
# latency-sensitive. Keep them off the planner/BT core so a planning burst does
# not falsely trip Nav2 bond timeout and tear down the command chain. Runtime
# children may inherit the old default from a long-lived API process, so migrate
# that exact inherited value when this policy is sourced.
if [[ -z "${NJRH_CPUSET_NAV2_MAP_SERVER:-}" || "${NJRH_CPUSET_NAV2_MAP_SERVER}" == "${NJRH_CPUSET_NAV_PLANNING}" ]]; then
  export NJRH_CPUSET_NAV2_MAP_SERVER="${NJRH_CPUSET_SYSTEM}"
else
  export NJRH_CPUSET_NAV2_MAP_SERVER
fi
if [[ -z "${NJRH_CPUSET_NAV2_LIFECYCLE_MANAGER:-}" || "${NJRH_CPUSET_NAV2_LIFECYCLE_MANAGER}" == "${NJRH_CPUSET_NAV_PLANNING}" || "${NJRH_CPUSET_NAV2_LIFECYCLE_MANAGER}" == "${NJRH_CPUSET_SYSTEM}" ]]; then
  export NJRH_CPUSET_NAV2_LIFECYCLE_MANAGER="${NJRH_CPUSET_NAV_SUPERVISION}"
else
  export NJRH_CPUSET_NAV2_LIFECYCLE_MANAGER
fi

export NJRH_CPUSET_FASTLIO_MAPPING="${NJRH_CPUSET_FASTLIO_MAPPING:-${NJRH_CPUSET_MAPPING_BACKEND}}"
export NJRH_CPUSET_FASTLIO_ODOM_BRIDGE="${NJRH_CPUSET_FASTLIO_ODOM_BRIDGE:-${NJRH_CPUSET_TF_STATE}}"
export NJRH_CPUSET_FASTLIO_DESKEW="${NJRH_CPUSET_FASTLIO_DESKEW:-${NJRH_CPUSET_MAPPING_FRONTEND}}"
export NJRH_CPUSET_SLAM_TOOLBOX_MAPPING="${NJRH_CPUSET_SLAM_TOOLBOX_MAPPING:-${NJRH_CPUSET_MAPPING_BACKEND}}"
export NJRH_CPUSET_PGO_MAPPING="${NJRH_CPUSET_PGO_MAPPING:-${NJRH_CPUSET_MAPPING_BACKEND}}"
